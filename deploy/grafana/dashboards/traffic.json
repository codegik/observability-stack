{
  "uid": "loan-traffic",
  "title": "Loan - Traffic",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requests (range)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({app=\"loan-backend\"} | json | http_status != `` [$__range]))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Errors 5xx (range)",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({app=\"loan-backend\"} | json | http_status =~ `5..` [$__range]))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Request rate by status (req/s)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (http_status) (rate({app=\"loan-backend\"} | json | http_status != `` [1m]))",
          "queryType": "range",
          "legendFormat": "{{http_status}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Latency ms (p50 / p95)",
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "quantile_over_time(0.5, {app=\"loan-backend\"} | json | http_status != `` | unwrap latency_ms [1m])",
          "queryType": "range",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "quantile_over_time(0.95, {app=\"loan-backend\"} | json | http_status != `` | unwrap latency_ms [1m])",
          "queryType": "range",
          "legendFormat": "p95"
        }
      ]
    }
  ]
}
