{
  "uid": "loan-runtime",
  "title": "Loan - JVM Runtime",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Heap / memory used",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (jvm_memory_type) (jvm_memory_used_bytes{job=~\".+\"})",
          "legendFormat": "{{jvm_memory_type}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Live threads",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jvm_thread_count)",
          "legendFormat": "threads"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "GC time rate (s/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(jvm_gc_duration_seconds_sum[1m]))",
          "legendFormat": "gc"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "CPU utilization",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jvm_cpu_recent_utilization_ratio",
          "legendFormat": "cpu"
        }
      ]
    }
  ]
}
