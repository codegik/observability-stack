{
  "uid": "loan-logs",
  "title": "Loan - Logs",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Log volume by level (lines/s)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (level) (rate({app=\"loan-backend\"} | json [1m]))",
          "queryType": "range",
          "legendFormat": "{{level}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "logs",
      "title": "All backend logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "wrapLogMessage": true, "enableLogDetails": true, "sortOrder": "Descending" },
      "gridPos": { "h": 11, "w": 24, "x": 0, "y": 7 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{app=\"loan-backend\"} | json",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 3,
      "type": "logs",
      "title": "Errors and 5xx",
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "wrapLogMessage": true, "enableLogDetails": true, "sortOrder": "Descending" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 18 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{app=\"loan-backend\"} | json | level = `ERROR` or http_status =~ `5..`",
          "queryType": "range"
        }
      ]
    }
  ]
}
