{
  "uid": "loan-traces",
  "title": "Loan - Traces",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Recent traces (loan-backend)",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name = \"loan-backend\" }",
          "tableType": "traces",
          "limit": 50
        }
      ]
    },
    {
      "id": 2,
      "type": "table",
      "title": "Error / slow traces (status>=500 or >1s)",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name = \"loan-backend\" && (span.http.status_code >= 500 || duration > 1s) }",
          "tableType": "traces",
          "limit": 50
        }
      ]
    }
  ]
}
